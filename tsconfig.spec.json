{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@auth/*": [
                "src/modules/auth/*"
            ],
            "@owner/*": [
                "src/modules/owner/*"
            ],
            "@veterinarian/*": [
                "src/modules/veterinarian/*"
            ],
            "@veterinary-clinics/*": [
                "src/modules/veterinary-clinics/*"
            ],
            "@pet/*": [
                "src/modules/pet/*"
            ],
            "@document/*": [
                "src/modules/document/*"
            ],
            "@medical-record/*": [
                "src/modules/medical-record/*"
            ],
            "@vaccination/*": [
                "src/modules/vaccination/*"
            ]
        }
    }
}