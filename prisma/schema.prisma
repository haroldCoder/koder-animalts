generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MedicalRecordType {
  CONSULTATION
  VACCINATION
  SURGERY
  EMERGENCY
  LAB_RESULTS
  HOSPITALIZATION
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  owner        Owner?
  veterinarian Veterinarian?
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(references: [id], fields: [userId], onDelete: Cascade)

  @@unique([token])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(references: [id], fields: [userId], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model VeterinaryClinic {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  veterinarians Veterinarian[]
  pets          Pet[]
  documents     Document[]
}

model Owner {
  id        String   @id @default(uuid())
  phone     String
  address   String

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  pets Pet[]
}

model Pet {
  id        String    @id @default(uuid())
  name      String
  species   String // e.g., Dog, Cat
  breed     String?
  birthDate DateTime?
  gender    String? // e.g., Male, Female
  weight    Float?
  color     String?
  microchip String?   @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  mainImage String
  iaImage   String?
  images    String[]  @default([])

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  clinicId String
  clinic   VeterinaryClinic @relation(fields: [clinicId], references: [id])

  medicalRecords MedicalRecord[]
  appointments   Appointment[]
  documents      Document[]
}

model Veterinarian {
  id        String   @id @default(uuid())
  phone     String
  specialty String?

  userId String @unique
  user   User @relation(fields: [userId], references: [id])

  clinicId String
  clinic   VeterinaryClinic @relation(fields: [clinicId], references: [id])

  medicalRecords MedicalRecord[]
  appointments   Appointment[]
}

model MedicalRecord {
  id             String   @id @default(uuid())
  visitDate      DateTime @default(now())
  type           MedicalRecordType @default(CONSULTATION)
  reasonForVisit String
  diagnosis      String?
  treatment      String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  petId String
  pet   Pet    @relation(fields: [petId], references: [id])

  veterinarianId String
  veterinarian   Veterinarian @relation(fields: [veterinarianId], references: [id])

  vaccinations Vaccination[]
  documents    Document[]
}

model Vaccination {
  id               String    @id @default(uuid())
  vaccineName      String
  dateAdministered DateTime  @default(now())
  nextDueDate      DateTime?
  lotNumber        String?
  createdAt        DateTime  @default(now())

  medicalRecordId String
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id])
}

model Appointment {
  id        String   @id @default(uuid())
  date      DateTime
  reason    String
  status    String   @default("SCHEDULED") // e.g., SCHEDULED, COMPLETED, CANCELLED
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  petId String
  pet   Pet    @relation(fields: [petId], references: [id])

  veterinarianId String
  veterinarian   Veterinarian @relation(fields: [veterinarianId], references: [id])
}

model Document {
  id        String   @id @default(uuid())
  title     String
  fileUrl   String
  fileKey   String? // For S3 or other storage providers
  fileSize  Int? // In bytes
  fileType  String? // MIME type
  category  String? // e.g., INVOICE, MEDICAL_REPORT, PET_PHOTO
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  petId String?
  pet   Pet?    @relation(fields: [petId], references: [id])

  medicalRecordId String?
  medicalRecord   MedicalRecord? @relation(fields: [medicalRecordId], references: [id])

  clinicId String?
  clinic   VeterinaryClinic? @relation(fields: [clinicId], references: [id])
}
